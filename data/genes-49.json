//pubmed.ncbi.nlm.nih.gov/19641380/"}],"genAgeHuman":null,"genAgeMouse":[],"organAge":[]}},"PCSK1":{"symbol":"PCSK1","annotation":{"approvedName":"proprotein convertase subtilisin/kexin type 1","hgncId":"HGNC:8743","chromosomeLocation":"5q15","chromosome":"5","locusGroup":"protein-coding gene","locusType":"gene with protein product","humanEntrezId":"5122","ensemblGeneId":"ENSG00000175426","uniprotIds":["P29120"],"aliases":["PC1","PC3","SPC3","PC1/3"],"previousSymbols":["NEC1"],"hgncUrl":"https://www.genenames.org/data/gene-symbol-report/#!/hgnc_id/HGNC%3A8743","ncbiMapLocation":"5q15","ncbiChromosome":"5","ncbiUrl":"https://www.ncbi.nlm.nih.gov/gene/5122"},"mouseOrtholog":{"homologyClassId":"51821902","humanSymbol":"PCSK1","humanEntrezId":"5122","humanHgncId":"HGNC:8743","humanLocation":"Chr5 q15","humanCoordinatesGrch38":"Chr5:96390333-96434143(-)","mouseSymbol":"Pcsk1","mouseEntrezId":"18548","mouseMgiId":"MGI:97511","mouseLocation":"Chr13 40.63 cM","mouseCoordinatesGrcm39":"Chr13:75237945-75282980(+)","mappingType":"one-to-one","source":"MGI/Alliance homology report","sourceUrl":"https://www.informatics.jax.org/downloads/reports/HOM_MouseHumanSequence.rpt"},"summary":"This gene encodes a member of the subtilisin-like proprotein convertase family, which includes proteases that process protein and peptide precursors trafficking through regulated or constitutive branches of the secretory pathway. The encoded protein undergoes an initial autocatalytic processing event in the ER to generate a heterodimer which exits the ER and sorts to subcellular compartments where a second autocatalytic even takes place and the catalytic activity is acquired. The protease is packaged into and activated in dense core secretory granules and expressed in the neuroendocrine system and brain. This gene encodes one of the seven basic amino acid-specific members which cleave their substrates at single or paired basic residues. It functions in the proteolytic activation of polypeptide hormones and neuropeptides precursors. Mutations in this gene have been associated with susceptibility to obesity and proprotein convertase 1/3 deficiency. Alternatively spliced transcript variants encoding multiple isoforms have been observed for this gene [provided by RefSeq, Jan 2014]","summarySource":{"label":"NCBI Gene","url":"https://www.ncbi.nlm.nih.gov/gene/5122","humanEntrezId":"5122"},"coverage":{"publicSourceCount":1,"publicSources":["longevityMap"],"evidenceLayerCount":1,"evidenceLayers":[{"key":"genomics","sources":["LongevityMap"]}],"organisms":["Human"],"transcriptomicContexts":[],"endpoints":["Longevity"]},"statistics":{"totalEvidenceRecords":1,"transcriptomicRecords":0,"transcriptomicPositive":0,"transcriptomicNegative":0,"epigeneticAgeCpGs":0,"epigeneticMortalityCpGs":0,"epigeneticMortalitySensitivitySupported":0,"longevityAssociations":1,"genAgeHumanRecords":0,"genAgeMouseRecords":0,"organAgeProteinOrganRecords":0,"organAgeOrgans":[],"bestReportedP":null},"evidence":{"transcriptomic":[],"epigeneticAge":[],"epigeneticMortality":[],"longevityMap":[{"recordId":"longevity:G493","sourceKey":"longevityMap","sourceFile":"longevity.csv","sourceRow":486,"reportId":"G493","sourceSymbol":"PCSK1","symbolMapping":"approved_symbol","association":"significant","population":"Korean","variants":"rs3811952,rs155979,rs3762985","pubmedId":19641380,"pubmedUrl":"https://pubmed.ncbi.nlm.nih.gov/19641380/"}],"genAgeHuman":null,"genAgeMouse":[],"organAge":[]}},"PDPK1":{"symbol":"PDPK1","annotation":{"approvedName":"3-phosphoinositide dependent protein kinase 1","hgncId":"HGNC:8816","chromosomeLocation":"16p13.3","chromosome":"16","locusGroup":"protein-coding gene","locusType":"gene with protein product","humanEntrezId":"5170","ensemblGeneId":"ENSG00000140992","uniprotIds":["O15530"],"aliases":["PDK1"],"previousSymbols":[],"hgncUrl":"https://www.genenames.org/data/gene-symbol-report/#!/hgnc_id/HGNC%3A8816","ncbiMapLocation":"16p13.3","ncbiChromosome":"16","ncbiUrl":"https://www.ncbi.nlm.nih.gov/gene/5170"},"mouseOrtholog":null,"summary":"Enables 3-phosphoinositide-dependent protein kinase activity; phospholipase activator activity; and phospholipase binding activity. Involved in several processes, including cell surface receptor signaling pathway; intracellular signaling cassette; and regulation of signal transduction. Acts upstream of or within intracellular signal transduction. Located in cell projection; cytosol; and plasma membrane. Implicated in prostate cancer. Biomarker of lung non-small cell carcinoma. [provided by Alliance of Genome Resources, Jul 2025]","summarySource":{"label":"NCBI Gene","url":"https://www.ncbi.nlm.nih.gov/gene/5170","humanEntrezId":"5170"},"coverage":{"publicSourceCount":1,"publicSources":["genAge"],"evidenceLayerCount":1,"evidenceLayers":[{"key":"genomics","sources":["GenAge"]}],"organisms":["Human"],"transcriptomicContexts":[],"endpoints":["Longevity"]},"statistics":{"totalEvidenceRecords":1,"transcriptomicRecords":0,"transcriptomicPositive":0,"transcriptomicNegative":0,"epigeneticAgeCpGs":0,"epigeneticMortalityCpGs":0,"epigeneticMortalitySensitivitySupported":0,"longevityAssociations":0,"genAgeHumanRecords":1,"genAgeMouseRecords":0,"organAgeProteinOrganRecords":0,"organAgeOrgans":[],"bestReportedP":null},"evidence":{"transcriptomic":[],"epigeneticAge":[],"epigeneticMortality":[],"longevityMap":[],"genAgeHuman":{"recordId":"genage:human:88","sourceKey":"genAge","sourceFile":"genage_human.csv","sourceRow":88,"organism":"Human","genAgeId":87,"sourceSymbol":"PDPK1","symbolMapping":"approved_symbol","geneName":"3-phosphoinositide dependent protein kinase 1","entrezGeneId":5170,"uniprotEntry":"PDPK1_HUMAN","evidenceBasis":["downstream"]},"genAgeMouse":[],"organAge":[]}},"PIN1":{"symbol":"PIN1","annotation":{"approvedName":"peptidylprolyl cis/trans isomerase, NIMA-interacting 1","hgncId":"HGNC:8988","chromosomeLocation":"19p13","chromosome":"19","locusGroup":"protein-coding gene","locusType":"gene with protein product","humanEntrezId":"5300","ensemblGeneId":"ENSG00000127445","uniprotIds":["Q13526"],"aliases":["dod"],"previousSymbols":[],"hgncUrl":"https://www.genenames.org/data/gene-symbol-report/#!/hgnc_id/HGNC%3A8988","ncbiMapLocation":"19p13.2","ncbiChromosome":"19","ncbiUrl":"https://www.ncbi.nlm.nih.gov/gene/5300"},"mouseOrtholog":null,"summary":"Peptidyl-prolyl cis/trans isomerases (PPIases) catalyze the cis/trans isomerization of peptidyl-prolyl peptide bonds. This gene encodes one of the PPIases, which specifically binds to phosphorylated ser/thr-pro motifs to catalytically regulate the post-phosphorylation conformation of its substrates. The conformational regulation catalyzed by this PPIase has a profound impact on key proteins involved in the regulation of cell growth, genotoxic and other stress responses, the immune response, induction and maintenance of pluripotency, germ cell development, neuronal differentiation, and survival. This enzyme also plays a key role in the pathogenesis of Alzheimer's disease and many cancers. Multiple alternatively spliced transcript variants have been found for this gene.[provided by RefSeq, Jun 2011]","summarySource":{"label":"NCBI Gene","url":"https://www.ncbi.nlm.nih.gov/gene/5300","humanEntrezId":"5300"},"coverage":{"publicSourceCount":1,"publicSources":["genAge"],"evidenceLayerCount":1,"evidenceLayers":[{"key":"genomics","sources":["GenAge"]}],"organisms":["Human"],"transcriptomicContexts":[],"endpoints":["Longevity"]},"statistics":{"totalEvidenceRecords":1,"transcriptomicRecords":0,"transcriptomicPositive":0,"transcriptomicNegative":0,"epigeneticAgeCpGs":0,"epigeneticMortalityCpGs":0,"epigeneticMortalitySensitivitySupported":0,"longevityAssociations":0,"genAgeHumanRecords":1,"genAgeMouseRecords":0,"organAgeProteinOrganRecords":0,"organAgeOrgans":[],"bestReportedP":null},"evidence":{"transcriptomic":[],"epigeneticAge":[],"epigeneticMortality":[],"longevityMap":[],"genAgeHuman":{"recordId":"genage:human:63","sourceKey":"genAge","sourceFile":"genage_human.csv","sourceRow":63,"organism":"Human","genAgeId":62,"sourceSymbol":"PIN1","symbolMapping":"approved_symbol","geneName":"peptidylprolyl cis/trans isomerase, NIMA-interacting 1","entrezGeneId":5300,"uniprotEntry":"PIN1_HUMAN","evidenceBasis":["upstream"]},"genAgeMouse":[],"organAge":[]}},"PMCH":{"symbol":"PMCH","annotation":{"approvedName":"pro-melanin concentrating hormone","hgncId":"HGNC:9109","chromosomeLocation":"12q23.2","chromosome":"12","locusGroup":"protein-coding gene","locusType":"gene with protein product","humanEntrezId":"5367","ensemblGeneId":"ENSG00000183395","uniprotIds":["P20382"],"aliases":["MCH"],"previousSymbols":[],"hgncUrl":"https://www.genenames.org/data/gene-symbol-report/#!/hgnc_id/HGNC%3A9109","ncbiMapLocation":"12q23.2","ncbiChromosome":"12","ncbiUrl":"https://www.ncbi.nlm.nih.gov/gene/5367"},"mouseOrtholog":null,"summary":"This gene encodes a preproprotein that is proteolytically processed to generate multiple protein products. These products include melanin-concentrating hormone (MCH), neuropeptide-glutamic acid-isoleucine (NEI), and neuropeptide-glycine-glutamic acid (NGE). Melanin-concentrating hormone is a 19-amino acid neuropeptide that stimulates hunger and may additionally regulate energy homeostasis, reproductive function, and sleep. Pseudogenes of this gene have been identified on chromosome 5. [provided by RefSeq, Jul 2015]","summarySource":{"label":"NCBI Gene","url":"https://www.ncbi.nlm.nih.gov/gene/5367","humanEntrezId":"5367"},"coverage":{"publicSourceCount":1,"publicSources":["genAge"],"evidenceLayerCount":1,"evidenceLayers":[{"key":"genomics","sources":["GenAge"]}],"organisms":["Human"],"transcriptomicContexts":[],"endpoints":["Longevity"]},"statistics":{"totalEvidenceRecords":1,"transcriptomicRecords":0,"transcriptomicPositive":0,"transcriptomicNegative":0,"epigeneticAgeCpGs":0,"epigeneticMortalityCpGs":0,"epigeneticMortalitySensitivitySupported":0,"longevityAssociations":0,"genAgeHumanRecords":